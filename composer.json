{
    "name": "opengeek/content-markdown-renderer",
    "description": "Markdown renderer for opengeek/content",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "opengeek/content": "^0.1.0",
        "michelf/php-markdown": "^2.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/opengeek/content"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "marcocesarato/php-conventional-changelog": "^1.17",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5",
        "symfony/console": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Opengeek\\Content\\MarkdownRenderer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Opengeek\\Content\\MarkdownRenderer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "validate": "composer validate --strict",
        "lint": "php-cs-fixer fix --dry-run --diff --verbose",
        "analyse": "phpstan analyse --memory-limit=1G",
        "test": "phpunit --colors=always",
        "test:coverage": "phpunit --coverage-clover build/logs/clover.xml",
        "ci": [
            "@validate",
            "@lint",
            "@analyse",
            "@test"
        ],
        "changelog": "conventional-changelog",
        "release": "conventional-changelog --commit",
        "release:patch": "conventional-changelog --patch --commit",
        "release:minor": "conventional-changelog --minor --commit",
        "release:major": "conventional-changelog --major --commit"
    }
}
